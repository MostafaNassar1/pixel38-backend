  "info": {
    "title": "Pixel38 CMS API",
    "description": "REST API for the wood products/services CMS — public website + admin dashboard",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@pixel38.com"
          },
          "password": {
            "type": "string",
            "example": "Admin123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateServiceDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Custom Furniture"
          },
          "description": {
            "type": "string",
            "example": "We craft bespoke wooden furniture to your specifications."
          },
          "icon": {
            "type": "string",
            "example": "hammer-icon"
          },
          "imageUrl": {
            "type": "string",
            "example": "https://example.com/service.jpg"
          },
          "order": {
            "type": "number",
            "example": 0
          }
        },
        "required": [
          "title",
          "description"
        ]
      },
      "UpdateServiceDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Custom Furniture"
          },
          "description": {
            "type": "string",
            "example": "Updated description"
          },
          "icon": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "order": {
            "type": "number"
          },
          "isActive": {
            "type": "boolean"
          }
        }
      },
      "HomepageSectionDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "a1b2c3d4-...",
            "description": "Omit to create a new section"
          },
          "section": {
            "type": "string",
            "example": "hero"
          },
          "title": {
            "type": "string",
            "example": "Quality Wood, Crafted with Care"
          },
          "subtitle": {
            "type": "string",
            "example": "Serving builders and homeowners since 1998"
          },
          "description": {
            "type": "string",
            "example": "Full description text here..."
          },
          "content": {
            "type": "object",
            "example": {
              "ctaText": "Shop Now",
              "ctaLink": "/products"
            }
          },
          "imageUrl": {
            "type": "string",
            "example": "https://example.com/hero.jpg"
          },
          "order": {
            "type": "number",
            "example": 0
          },
          "isActive": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Oak Hardwood"
          },
          "description": {
            "type": "string",
            "example": "Premium oak hardwood, ideal for flooring and furniture."
          },
          "category": {
            "type": "string",
            "example": "Hardwood"
          },
          "price": {
            "type": "number",
            "example": 45.99
          },
          "traits": {
            "example": [
              {
                "label": "Durability",
                "positive": true
              },
              {
                "label": "Expensive",
                "positive": false
              }
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "description",
          "category"
        ]
      },
      "UpdateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Oak Hardwood"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "isActive": {
            "type": "boolean"
          },
          "traits": {
            "example": [
              {
                "label": "Durability",
                "positive": true
              },
              {
                "label": "Expensive",
                "positive": false
              }
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AddProductImageDto": {
        "type": "object",
        "properties": {
          "imageUrl": {
            "type": "string",
            "example": "/uploads/1234567-891234.jpg"
          },
          "order": {
            "type": "number",
            "example": 0
          }
        },
        "required": [
          "imageUrl"
        ]
      },
      "ReorderImagesDto": {
        "type": "object",
        "properties": {
          "imageIds": {
            "example": [
              "image-id-1",
              "image-id-2",
              "image-id-3"
            ],
            "description": "Array of image IDs in the desired new order",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "imageIds"
        ]
      }
    }
  }
}